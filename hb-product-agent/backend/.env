# 数据库配置 — 统一使用 seekdb 嵌入式模式（OceanBase）
SEEKDB_PATH=./seekdb_data
SEEKDB_DB=product_agent

# 阿里云百炼配置 (必填)
# 文档地址: https://bailian.console.aliyun.com/
BAILIAN_API_KEY=sk-e5c0840c7f91424cb9dee87f5cb20e6d
BAILIAN_APP_ID=your-app-id-here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 百炼模型（qwen-plus 速度快且质量均衡，qwen-turbo 最快）
LLM_MODEL=qwen-plus

# 应用配置
APP_DEBUG=true
APP_PORT=8000
