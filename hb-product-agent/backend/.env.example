# 数据库配置
# 开发环境使用 SQLite，生产环境切换为 seekdb (MySQL 协议)
DB_TYPE=sqlite
DB_URL=sqlite:///./hb_agent.db

# 生产环境 seekdb 配置示例
# DB_TYPE=mysql
# DB_URL=mysql+pymysql://root:root@localhost:2881/hb_agent

# 阿里云百炼配置 (必填)
# 文档地址: https://bailian.console.aliyun.com/
BAILIAN_API_KEY=sk-e5c0840c7f91424cb9dee87f5cb20e6d
BAILIAN_APP_ID=your-app-id-here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 应用配置
APP_DEBUG=true
APP_PORT=18080
APP_BASE_URL=http://localhost:18080

# 钉钉机器人配置
DINGTALK_CLIENT_ID=your_app_key
DINGTALK_CLIENT_SECRET=your_app_secret
DINGTALK_ROBOT_CODE=your_app_key
DINGTALK_ENABLED=false
