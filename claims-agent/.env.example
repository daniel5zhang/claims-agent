# Django
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库
DATABASE_URL=sqlite:///./data/db.sqlite3
READONLY_DB_URL=postgresql://dbadmin:password@192.168.0.48:8000/hmb

# 模型 API（百炼 DashScope 兼容模式，Qwen + DeepSeek 共用同一 API Key）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 主模型/备用模型配置（API model ID）
PRIMARY_MODEL=qwen3.6-plus
FALLBACK_MODEL=deepseek-v4-pro
FLASH_MODEL=qwen3.6-flash
LARGE_CONTEXT_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-v3

# 存储
ATTACHMENT_STORAGE=local              # local / oss
LOCAL_ATTACHMENT_PATH=./data/attachments

# 钉钉 SSO
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_CORP_ID=

# 企微 SSO
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# 通知 Webhook
DINGTALK_NOTIFY_WEBHOOK=
WECOM_NOTIFY_WEBHOOK=

# 外部回调安全
PHARMACY_WEBHOOK_SECRET=
INSURER_WEBHOOK_SECRET=

# 监控
SENTRY_DSN=

# Huey
HUEY_DB_PATH=./data/huey.db
MAX_CONCURRENCY=3
